---
import Base from '../layouts/Base.astro';
---
<Base
  title="The Well"
  description="An open-source database of judicial procedure — standing orders, filing preferences, and motion practice for federal and California state judges."
>
  <section>
    <h1 class="text-3xl mb-4">The Well</h1>
    <p class="text-lg mb-6" style="color: var(--color-muted)">
      An open-source database of judicial procedure.
    </p>
    <p class="mb-4">
      The Well aggregates standing orders, local rules, and filing preferences
      for federal and California state judges. Every field is sourced. Verified
      California-barred attorneys contribute observations anonymously.
    </p>
    <p class="mb-4">
      The site is being rebuilt. Judge pages will appear as jurisdictions come
      online — starting with the Southern District of California.
    </p>
    <p class="font-sans text-sm mt-8">
      <a href="/j/" class="mr-4">Browse judges</a>
      <a href="/about/" class="mr-4">About</a>
      <a href="/contribute/">Contribute</a>
    </p>
  </section>
</Base>
